# BlinkChat Client — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# See README.md § 10 for full documentation on every variable.
#
# All variables MUST be prefixed with VITE_ to be accessible in the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API / BACKEND ───────────────────────────────────────────────────────────

VITE_API_URL=/api
# Base URL for all HTTP API requests.
#
# LOCAL DEVELOPMENT → use /api (relative)
#   Vite's dev proxy forwards /api/* to http://localhost:5000.
#   Do NOT use http://localhost:5000/api here — that bypasses the proxy
#   and causes CORS errors.
#
# PRODUCTION → use full backend URL
#   Example: https://api.yourapp.com/api

VITE_SOCKET_URL=/
# URL that Socket.IO connects to.
#
# LOCAL DEVELOPMENT → use / (root)
#   Vite's dev proxy forwards /socket.io/* to http://localhost:5000.
#
# PRODUCTION → use the root URL of your backend (not the /api path)
#   Example: https://api.yourapp.com

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# REQUIRED for "Sign in with Google" to work.
# Must match the GOOGLE_CLIENT_ID set on the server.
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
#
# Add your frontend origin to "Authorised JavaScript origins" in Google Cloud:
#   - http://localhost:5173    (development)
#   - https://yourapp.com     (production)
