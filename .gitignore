# ─── Environment & Secrets (NEVER commit these) ───────────────────────────────
.env
.env.*
!.env.example
server/.env
server/.env.*

# ─── Node dependencies ────────────────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ─── Build outputs (generated by Docker, not needed in repo) ──────────────────
client/dist/
server/dist/

# ─── SSH Keys & Certificates (CRITICAL - never commit) ────────────────────────
*.pem
*.key
*.crt
*.p12

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ─── OS generated files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ─── Editor files ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
client/coverage/
server/coverage/

# ─── Docker (local override files only) ───────────────────────────────────────
docker-compose.override.yml
