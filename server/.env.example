```env
# BlinkChat Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# See README.md § 10 for full documentation on every variable.
#
# IMPORTANT:
# Never commit your real .env file to GitHub.
# Only commit this .env.example file.
# ─────────────────────────────────────────────────────────────────────────────

# ─── CORE SERVER ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ────────────────────────────────────────────────────────────────
# REQUIRED. Replica set needed in production (transactions are used).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/blinkChat?retryWrites=true&w=majority

# ─── JWT / TOKENS ────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=15m

# REQUIRED. Must be different from JWT_SECRET.
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string

# OPTIONAL. Signs OTP proof tokens. Falls back to JWT_SECRET if not set.
OTP_PROOF_SECRET=replace_with_yet_another_long_random_string

# ─── FRONTEND / CORS ─────────────────────────────────────────────────────────
# REQUIRED in production. Comma-separated list of allowed frontend origins.
# In development, localhost:3000 / 5173 / 4173 are allowed by default.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── COOKIES ─────────────────────────────────────────────────────────────────
# Only needed when frontend and backend are on different domains.
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.yourdomain.com
# REFRESH_COOKIE_PATH=/

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
# REQUIRED for Google login. Must match the Client ID in the frontend.
# Get it from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── EMAIL / OTP (RESEND) ────────────────────────────────────────────────────
# REQUIRED. Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender address. Use a verified domain in production.
# Default: onboarding@resend.dev (Resend sandbox — fine for testing only)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── OTP BEHAVIOUR ───────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
MAX_ATTEMPTS=5
MAX_SENDS_PER_WINDOW=3
VERIFIED_TOKEN_EXPIRY=15m
BCRYPT_ROUNDS=10

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────
# REQUIRED. All four variables are needed for file uploads to work.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your_cloud_name

# ─── UPLOAD LIMITS ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# Comma-separated allowed MIME types. All uploads are blocked if this is empty.
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,audio/webm,audio/mpeg,audio/mp4,audio/wav,audio/ogg,video/mp4,video/webm,application/pdf

# ─── WEBRTC / STUN / TURN ────────────────────────────────────────────────────
# STUN — falls back to Google's public servers if not set.
STUN_URL_1=stun:stun.l.google.com:19302
STUN_URL_2=stun:stun1.l.google.com:19302

# TURN — needed for calls across strict NAT or corporate firewalls.
# Recommended: self-host coturn. See README.md § 14 for setup guide.

# TURN_URL=turn:your.turn.server:3478
# TURN_TLS_URL=turns:your.turn.server:5349
# TURN_SECRET=your_coturn_shared_secret

# How long generated TURN credentials remain valid (seconds).
# Default: 86400 (24 hours)
# TURN_TTL_SECONDS=86400
```
